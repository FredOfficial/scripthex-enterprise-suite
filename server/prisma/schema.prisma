generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  users     User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  provider  String   @default("local")

  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  PROBATIONARY
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Position {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Employee {
  id           Int            @id @default(autoincrement())
  employeeNo   String         @unique

  photo        String?
  qrCode       String?
  rfidCard     String?

  firstName    String
  middleName   String?
  lastName     String
  suffix       String?

  gender       String?
  birthDate    DateTime?
  civilStatus  String?
  nationality  String?

  email        String?        @unique
  phone        String?
  address      String?

  emergencyContactName  String?
  emergencyContactPhone String?

  departmentId Int?
  positionId   Int?

  department   Department?    @relation(fields: [departmentId], references: [id])
  position     Position?      @relation(fields: [positionId], references: [id])

  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)

  hiredAt      DateTime
  salary       Decimal?         @db.Decimal(10, 2)

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  attendances Attendance[]

  workScheduleId Int?
  workSchedule   WorkSchedule? @relation(fields: [workScheduleId], references: [id])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  module      String
  description String
  actor       String   @default("System Administrator")
  createdAt   DateTime @default(now())
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
}

model Attendance {
  id           Int              @id @default(autoincrement())
  employeeId   Int
  employee     Employee         @relation(fields: [employeeId], references: [id])

  date         DateTime
  timeIn       DateTime?
  timeOut      DateTime?

  status       AttendanceStatus @default(PRESENT)

  workingHours Int?
  lateMinutes  Int?

  remarks      String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkSchedule {
  id          Int      @id @default(autoincrement())
  name        String   @unique

  startTime   String
  endTime     String
  gracePeriod Int      @default(0)

  isNightShift Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
  breaks    WorkScheduleBreak[]
}

model WorkScheduleBreak {
  id             Int      @id @default(autoincrement())
  workScheduleId Int

  name           String
  startTime      String
  endTime        String
  isPaid         Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id])
}